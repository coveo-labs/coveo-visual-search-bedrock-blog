# API Gateway URL (get from CloudFormation output after deployment)
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# Coveo Configuration
VITE_COVEO_ORG_ID=your-coveo-org-id
VITE_COVEO_API_KEY=your-coveo-search-api-key
VITE_COVEO_SEARCH_HUB=LuxuryImageSearch
VITE_COVEO_PIPELINE=hermes

# Analytics
VITE_ENABLE_ANALYTICS=true
